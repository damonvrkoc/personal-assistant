# Channel toggles (defaults in application.yaml: Slack on, WhatsApp off)
CHANNEL_WHATSAPP_ENABLED=false
CHANNEL_SLACK_ENABLED=true

# Slack Socket Mode
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# DM on startup (handle, display name, or Slack user ID U...)
SLACK_STARTUP_NOTIFY_ENABLED=true
SLACK_STARTUP_NOTIFY_USER=damon.vrkoc

# WhatsApp Cloud API (only when CHANNEL_WHATSAPP_ENABLED=true)
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_APP_SECRET=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=

OPENAI_API_KEY=
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Optional: restrict who can chat while testing
# ALLOWED_SLACK_USER_IDS=U012ABC,U034DEF
# ALLOWED_WA_IDS=15551234567,15559876543
